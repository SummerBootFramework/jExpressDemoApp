  "components" : {
    "schemas" : {
      "Err" : {
        "type" : "object",
        "properties" : {
          "errorCode" : {
            "type" : "string"
          },
          "errorTag" : {
            "type" : "string"
          },
          "errorDesc" : {
            "type" : "string"
          }
        },
        "description" : "The optional error list"
      },
      "ServiceError" : {
        "required" : [ "ref" ],
        "type" : "object",
        "properties" : {
          "ref" : {
            "type" : "string",
            "description" : "The index of requests received by current server since start"
          },
          "errors" : {
            "type" : "array",
            "description" : "The optional error list",
            "items" : {
              "$ref" : "#/components/schemas/Err"
            }
          }
        }
      },
      "MyResponse" : {
        "type" : "object",
        "properties" : {
          "publicInfo" : {
            "type" : "string"
          },
          "privateInfo" : {
            "type" : "string"
          },
          "secretList" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "emptyList" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "nullList" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "dataList" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "pdfBase64" : {
            "type" : "string"
          },
          "pdfCrc" : {
            "type" : "integer",
            "format" : "int64"
          },
          "imageBase64" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          }
        }
      },
      "MyRequest" : {
        "required" : [ "creditCardNumber", "shoppingList" ],
        "type" : "object",
        "properties" : {
          "creditCardNumber" : {
            "minLength" : 1,
            "type" : "string"
          },
          "ownerPwd" : {
            "type" : "string"
          },
          "userPwd" : {
            "type" : "string"
          },
          "pdfVersion" : {
            "type" : "number",
            "format" : "float"
          },
          "shoppingList" : {
            "minItems" : 1,
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          }
        }
      },
      "Caller" : {
        "type" : "object",
        "properties" : {
          "enabled" : {
            "type" : "boolean"
          },
          "id" : {
            "type" : "number"
          },
          "type" : {
            "type" : "integer",
            "format" : "int32"
          },
          "displayName" : {
            "type" : "string"
          },
          "uid" : {
            "type" : "string"
          },
          "jti" : {
            "type" : "string"
          },
          "groups" : {
            "uniqueItems" : true,
            "type" : "array",
            "items" : {
              "type" : "string"
